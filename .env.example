# Copy this file to `.env` in the same folder (`financial_distress/`) and set your key there.
# The app loads `.env` first. It will only read `.env.example` if `.env` has no key (not recommended for production).
# Never commit a real key in this file.

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional (OpenRouter attribution headers)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Financial Distress Prediction
